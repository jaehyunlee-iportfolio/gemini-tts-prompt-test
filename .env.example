# =============================================================================
# 로컬: 이 파일을 복사해 비밀값만 채웁니다.
#   cp .env.example .env.local
# Next.js는 .env.local을 자동 로드합니다(.gitignore에 포함됨).
# =============================================================================

# --- TTS (필수) ---
TTS_AUTH_TOKEN=

# --- CSV 배치·STT QA (선택) — /api/stt-verify, OpenAI 전사 기본 gpt-4o-transcribe ---
# 로컬: .env.local / Vercel: Environment Variables에만 넣고 클라이언트·Git에 커밋하지 않음.
OPENAI_API_KEY=
# OPENAI_STT_MODEL=gpt-4o-transcribe

# --- CSV 전용 Gemini 네이티브 TTS (선택) — UI에서 "CSV만 Gemini API" 켠 경우 /api/gemini-tts
# https://ai.google.dev/gemini-api/docs/speech-generation
GEMINI_API_KEY=
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview

# --- Google 로그인 (Auth.js v5) ---
# AUTH_SECRET 생성: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- 레지스트리 추가 관리자(선택, 쉼표 구분, @iportfolio.co.kr 만) ---
# REGISTRY_ADMIN_EMAILS=

# --- Firebase Admin (선택) — 로그인 사용자별 TTS 결과 이력 Firestore 저장 ---
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키(JSON)에서 project_id, client_email, private_key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# 한 줄로 넣을 때 줄바꿈은 \n 로 이스케이프 (Vercel 멀티라인 JSON에서 복사한 키 형식)
FIREBASE_PRIVATE_KEY=

# --- GitHub Contents API (레지스트리 웹 저장·GitHub에서 registry 로드) ---
# PAT는 GITHUB_TOKEN 또는 GH_TOKEN 중 하나만 있으면 됩니다.
GITHUB_TOKEN=
# GH_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
# GITHUB_BRANCH=main
